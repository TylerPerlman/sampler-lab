    path = ROOT / "README.md"
    text = path.read_text(encoding="utf-8")
    old = (
        "[orientation and diagnostics](docs/notebooks/00_orientation_and_diagnostics.ipynb), then continue to\n"
        "[exact and IID sampling](docs/notebooks/01_exact_and_iid_sampling.ipynb) or\n"
        "[importance sampling](docs/notebooks/02_importance_sampling.ipynb)."
    )
    new = (
        "[orientation and diagnostics](docs/notebooks/00_orientation_and_diagnostics.ipynb), then continue to\n"
        "[exact and IID sampling](docs/notebooks/01_exact_and_iid_sampling.ipynb),\n"
        "[importance sampling](docs/notebooks/02_importance_sampling.ipynb), or the sequential series from\n"
        "[particle methods](docs/notebooks/03_particle_methods.ipynb) through\n"
        "[Metropolis, Gibbs, and Ising](docs/notebooks/05_metropolis_gibbs_and_ising.ipynb)."
    )
    if old not in text:
        raise RuntimeError("README tutorial paragraph not found")
    path.write_text(text.replace(old, new), encoding="utf-8")


def main() -> None:
    write_notebook("03_particle_methods.ipynb", particle_notebook())
    write_notebook("04_finite_state_markov_theory.ipynb", markov_notebook())
    write_notebook("05_metropolis_gibbs_and_ising.ipynb", mcmc_notebook())
    write_notebook("06_annealed_paths_and_free_energy.ipynb", annealing_notebook())
    update_manifest()
    update_index()
    update_mkdocs()
    update_method_links()
    update_readme()
    print("Generated PR 2 notebook sources and documentation links")

